  "expert_card_schema": {
    "description": "AX-On 플랫폼 카드에 표시되는 최소 정보",
    "fields": {
      "id": { "type": "string", "description": "고유 식별자 (UUID 권장)" },
      "name": { "type": "string", "required": true, "description": "전문가 실명" },
      "profile_image": { "type": "string", "required": true, "description": "프로필 이미지 URL (외부 URL 허용)" },
      "industries": {
        "type": "array",
        "items": "string (industry.id)",
        "required": true,
        "description": "담당 산업 분류 (최대 3개 권장)"
      },
      "functions": {
        "type": "array",
        "items": "string (function.id)",
        "required": true,
        "description": "담당 기능 분야 (최대 3개 권장)"
      },
      "tagline": { "type": "string", "maxLength": 60, "required": true, "description": "한 줄 소개" },
      "external_url": { "type": "string", "format": "url", "required": true, "description": "전문가 개인 페이지 URL (GitHub Pages 등)" },
      "status": {
        "type": "string",
        "enum": ["active", "inactive", "pending"],
        "default": "pending",
        "description": "활동 상태"
      },
      "created_at": { "type": "string", "format": "datetime" },
      "updated_at": { "type": "string", "format": "datetime" }
    }
  },
  "supabase_sql": "CREATE TABLE experts (\n  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n  name TEXT NOT NULL,\n  profile_image TEXT NOT NULL,\n  industries TEXT[] NOT NULL DEFAULT '{}',\n  functions TEXT[] NOT NULL DEFAULT '{}',\n  tagline TEXT NOT NULL CHECK (char_length(tagline) <= 60),\n  external_url TEXT NOT NULL,\n  status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('active', 'inactive', 'pending')),\n  created_at TIMESTAMPTZ DEFAULT now(),\n  updated_at TIMESTAMPTZ DEFAULT now()\n);",
